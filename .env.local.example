# ==============================================================================
# IDS.online Order Intelligence Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase (required)
# Found in: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------------------------
# Application URL (required for invite emails and auth redirects)
# Local dev: http://localhost:3000
# Production: https://your-domain.com
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Session inactivity timeout (optional, default: 8 hours)
# Users are signed out after this many hours of inactivity.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SESSION_TIMEOUT_HOURS=8

# ------------------------------------------------------------------------------
# Cron Job Secret (required for scheduled cleanup tasks)
# Generate a random string: openssl rand -base64 32
# Vercel: Set in Project Settings → Environment Variables
# ------------------------------------------------------------------------------
CRON_SECRET=your-cron-secret-here

# ------------------------------------------------------------------------------
# Anthropic API Key (required for OPH-4: AI Extraction)
# Get your key at: https://console.anthropic.com/settings/keys
# Used to call Claude API for order data extraction.
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ------------------------------------------------------------------------------
# Extraction Model (optional, default: claude-sonnet-4-6)
# Override the Claude model used for extraction.
# Options: claude-opus-4-6, claude-sonnet-4-6
# ------------------------------------------------------------------------------
# EXTRACTION_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------------------------
# Postmark (required for OPH-10: Email Ingestion)
# Postmark handles inbound email parsing and confirmation email sending.
# Generate a random webhook token: openssl rand -base64 32
# Then set your Postmark inbound webhook URL to:
#   https://your-app.vercel.app/api/inbound/email?token=YOUR_TOKEN_HERE
# ------------------------------------------------------------------------------
POSTMARK_INBOUND_WEBHOOK_TOKEN=dd0980da28053875893e245e635343ea1aca43bb8bb727439bd9d017f066749e
POSTMARK_SERVER_API_TOKEN=e51c1de0-4b09-4dc0-b867-dde93dee9f98
INBOUND_EMAIL_DOMAIN=oph.ids.online

# ------------------------------------------------------------------------------
# Postmark Sender Email (optional, overrides auto-derived sender)
# Use this when NEXT_PUBLIC_SITE_URL is not your verified Postmark sender domain.
# Must be a verified sender address or Sender Signature in Postmark.
# ------------------------------------------------------------------------------
POSTMARK_SENDER_EMAIL=message-from-oph@oph.ids.online

# ------------------------------------------------------------------------------
# Platform Admin Email (required for OPH-16: Trial expiry notifications)
# The email address that receives trial expiry alerts from the daily cron job.
# ------------------------------------------------------------------------------
PLATFORM_ADMIN_EMAIL=michael.mollath@ids.online
