# ==============================================================================
# IDS.online Order Intelligence Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase (required)
# Found in: Supabase Dashboard → Project Settings → API
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ------------------------------------------------------------------------------
# Application URL (required for invite emails and auth redirects)
# Local dev: http://localhost:3000
# Production: https://your-domain.com
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Session inactivity timeout (optional, default: 8 hours)
# Users are signed out after this many hours of inactivity.
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SESSION_TIMEOUT_HOURS=8

# ------------------------------------------------------------------------------
# Cron Job Secret (required for scheduled cleanup tasks)
# Generate a random string: openssl rand -base64 32
# Vercel: Set in Project Settings → Environment Variables
# ------------------------------------------------------------------------------
CRON_SECRET=your-cron-secret-here
